# 复制为 .env 或 .env.txt 后填写（勿提交真实密钥到 Git）
#
# Reverb Personal Access Token（后端仅此变量读取 PAT）
REVERB_API_TOKEN=

# ExchangeRate-API（https://www.exchangerate-api.com/）v6 密钥，用于 /api/exchange-rate
EXCHANGE_RATE_API_KEY=

# JWT（登录签发 HS256；须为长随机串，勿泄露）
JWT_SECRET_KEY=
# 可选：令牌有效期（分钟），默认 10080（7 天）
# JWT_EXPIRE_MINUTES=10080

# 可选：覆盖默认 sqlite:///…/guitar_search.db
# DATABASE_URL=sqlite:///./guitar_search.db
